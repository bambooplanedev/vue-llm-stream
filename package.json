{
  "name": "vue-llm-stream",
  "version": "0.3.0",
  "description": "Streaming LLM responses for Vue 3 — SSE parsing, resilient retries, and token-by-token markdown rendering with live syntax highlighting.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bambooplanedev/vue-llm-stream.git"
  },
  "homepage": "https://github.com/bambooplanedev/vue-llm-stream#readme",
  "bugs": {
    "url": "https://github.com/bambooplanedev/vue-llm-stream/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "default": "./dist/providers.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "default": "./dist/markdown.js"
    },
    "./theme.css": "./dist/theme.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist && node scripts/fix-vue-dts.mjs && node -e \"require('node:fs').copyFileSync('src/theme.css', 'dist/theme.css')\"",
    "check:package": "publint && attw --pack . --profile esm-only --exclude-entrypoints ./theme.css",
    "prepublishOnly": "npm run build && npm run check:package",
    "play": "vite --config playground/vite.config.ts playground",
    "play:build": "vite build --config playground/vite.config.ts playground"
  },
  "keywords": [
    "vue",
    "llm",
    "streaming",
    "sse",
    "markdown",
    "anthropic",
    "openai",
    "llama.cpp"
  ],
  "peerDependencies": {
    "markdown-it": "^14.0.0",
    "shiki": "^1.22.0 || ^2.0.0 || ^3.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^20.11.0",
    "markdown-it": "^14.0.0",
    "publint": "^0.2.0",
    "shiki": "^1.22.0",
    "typescript": "^5.5.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.4.0",
    "vue-tsc": "^2.1.0"
  }
}
